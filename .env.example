# Supabase (public — safe to expose, anon key is the publishable key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Resend (email) — SECRET: do not share
RESEND_API_KEY=re_xxxxxxxxxxxx

# Verified From Email (must be verified in Resend dashboard)
RESEND_VERIFIED_FROM_EMAIL=Play To Network <onboarding@resend.dev>

# Tournament Configuration (public)
NEXT_PUBLIC_TOURNAMENT_ID=8681b997-c81b-4395-89f4-2792e3be75e5
NEXT_PUBLIC_TOURNAMENT_NAME=Play To Network 3v3 Mini Football Tournament
NEXT_PUBLIC_TOURNAMENT_DATE=Sunday, July 12th
NEXT_PUBLIC_TOURNAMENT_LOCATION=Hyperdrive Arena

# Fee Configuration (set via environment on the server)
TOURNAMENT_TEAM_FEE=3000
TOURNAMENT_INDIVIDUAL_FEE=600

# Feature Flags (public)
NEXT_PUBLIC_USE_LIVE_REGISTRATION=true
NEXT_PUBLIC_USE_LIVE_ADMIN=true
NEXT_PUBLIC_USE_LIVE_EVENTS=true
NEXT_PUBLIC_USE_LIVE_TOURNAMENT_DETAILS=true

# Email From Address
EMAIL_FROM=Play To Network <onboarding@resend.dev>
